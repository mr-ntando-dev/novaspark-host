{
  "name": "My WhatsApp Bot",
  "description": "A WhatsApp bot with 130+ commands",
  "entry_point": "index.js",
  "branch": "main",
  "server_tier": "basic",
  "auto_restart": true,
  "max_ram_mb": 512,
  "region": "us-east-1",
  "plugins": ["anti-crash", "analytics-tracker"],
  "pipeline": {
    "name": "Default Deploy",
    "steps": [
      { "type": "backup" },
      { "type": "git_pull" },
      { "type": "npm_install" },
      { "type": "deploy" },
      { "type": "health_check", "port": 3000 },
      { "type": "notify" }
    ]
  },
  "rate_limit": {
    "requests_per_minute": 60,
    "auto_block_threshold": 5
  },
  "env": {
    "BOT_TOKEN": {
      "description": "Your bot token",
      "required": true
    },
    "PREFIX": {
      "description": "Command prefix",
      "required": false,
      "default": "!"
    },
    "DATABASE_URL": {
      "description": "Database connection string",
      "required": false
    }
  }
}
