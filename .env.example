# --- NovaSpark V13 Environment Variables ---
PORT=3000
NODE_ENV=development

# Public URL (set to your Render URL in production)
RENDER_URL=http://localhost:3000

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Admin credentials (created on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=novaspark2025

# Discord Webhook (optional - for crash/alert notifications)
DISCORD_WEBHOOK_URL=

# Stripe (optional - for auto-billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Bot hosting
BOT_MAX_RAM_MB=512
BOT_WATCHDOG_INTERVAL_MS=120000
MAX_BOTS_GLOBAL=100

# GitHub token (optional - for private repo cloning)
GITHUB_TOKEN=

# --- V13 FEATURES ---

# Vault encryption key (32+ chars recommended, falls back to JWT_SECRET)
VAULT_ENCRYPTION_KEY=

# Default deploy region (see /api/regions for available options)
DEFAULT_REGION=us-east-1

# CI/CD Pipeline webhook secret (for GitHub/GitLab integration)
PIPELINE_WEBHOOK_SECRET=

# Anomaly detection sensitivity (1-10, higher = more sensitive)
ANOMALY_SENSITIVITY=5

# Rate limiter defaults
DEFAULT_RATE_LIMIT_RPM=60
DEFAULT_RATE_LIMIT_RPH=1000

# Plugin marketplace (set to your marketplace URL if self-hosted)
PLUGIN_MARKETPLACE_URL=
