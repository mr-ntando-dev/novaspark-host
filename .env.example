# ─── NovaSpark V11 Environment Variables ───────────────────────────────────
PORT=3000
NODE_ENV=development

# Public URL (set to your Render URL in production)
RENDER_URL=http://localhost:3000

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Admin credentials (created on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Discord Webhook (optional - for crash/alert notifications)
DISCORD_WEBHOOK_URL=

# Stripe (optional - for auto-billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Bot hosting
BOT_MAX_RAM_MB=512
BOT_WATCHDOG_INTERVAL_MS=120000
MAX_BOTS_GLOBAL=100
